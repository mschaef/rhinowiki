{:app {:name "Rhinowiki"}
 :http-port 8080
 :development-mode false

 :rhinowiki-repository "https://github.com/mschaef/rhinowiki"

 :rss-spec-location "https://cyber.harvard.edu/rss/"

 :blog-defaults  {:recent-post-limit 4
                   :feed-post-limit 20
                   :contents-post-limit 100

                   :date-format {:articles-header "MMMM dd, yyyy"
                                 :contents-header "MMMM yyyy"
                                 :article-header "MMMM d, y"}

                   :language "en-US"}

 ;; Secret token required in the X-Invalidate-Token header for POST /invalidate.
 ;; If nil (the default), the endpoint rejects all requests.
 :invalidate-token nil

 :blog-overrides {}

 ;; Map of hostname -> storage spec for each hosted site.
 ;; Example:
 ;;   :sites {"blog.example.com" {:source :git :repo-path "/home/git/blog.git"}
 ;;           "notes.example.com" {:source :git :repo-path "/home/git/notes.git"}}
 :sites {}

 ;; Optional fallback hostname used when the Host header doesn't match any
 ;; entry in :sites (e.g. localhost in development, or curl without a Host
 ;; header). The value must be a key already present in :sites.
 ;; Example: :default-site "blog.example.com"
 :default-site nil}
